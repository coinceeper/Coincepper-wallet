# ============================================================
# CoinCeeper Wallet — Environment Variables Example
# ============================================================
# Copy this file to .env or pass via --dart-define at build time.
#
# Usage:
#   flutter run --dart-define=ETHERSCAN_API_KEY=YOUR_KEY
#
# Or use the helper script:
#   powershell -File scripts/run_with_keys.ps1
# ============================================================

# ═══════════════════════════════════════════════════════════
# 1. Explorer API Keys (for on-chain history)
# ═══════════════════════════════════════════════════════════
# Register at:
#   https://etherscan.io/register
#   https://bscscan.com/register
#   https://polygonscan.com/register
#   https://snowtrace.io/register
#   https://arbiscan.io/register
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=
AVALANCHE_API_KEY=
ARBITRUMSCAN_API_KEY=

# ═══════════════════════════════════════════════════════════
# 2. TronGrid (3 keys for 45 req/sec load balancing)
# ═══════════════════════════════════════════════════════════
# Register: https://www.trongrid.io/
TRONGRID_API_KEY_1=
TRONGRID_API_KEY_2=
TRONGRID_API_KEY_3=

# ═══════════════════════════════════════════════════════════
# 3. RPC Providers (optional — public endpoints work too)
# ═══════════════════════════════════════════════════════════
# dRPC: https://drpc.org/
DRPC_API_KEY=
# Ankr: https://www.ankr.com/
ANKR_API_KEY=
# Chainstack: https://chainstack.com/
CHAINSTACK_ETH_TOKEN=
CHAINSTACK_BTC_TOKEN=
# Tenderly: https://tenderly.co/
TENDERLY_API_KEY=
TENDERLY_ETH_RPC_URL=
TENDERLY_ETH_WSS_URL=
# Etox
ETOX_API_KEY=
ETOX_ETH_RPC_URL=
# BlockPI
BLOCKPI_ETH_RPC_URL=

# ═══════════════════════════════════════════════════════════
# 4. Solana
# ═══════════════════════════════════════════════════════════
# Helius: https://helius.xyz/
HELIUS_API_KEY=

# ═══════════════════════════════════════════════════════════
# 5. Polkadot
# ═══════════════════════════════════════════════════════════
SUBSCAN_API_KEY_1=
SUBSCAN_API_KEY_2=

# ═══════════════════════════════════════════════════════════
# 6. Bitcoin
# ═══════════════════════════════════════════════════════════
# BlockCypher: https://www.blockcypher.com/
BLOCKCYPHER_API_KEY_1=

# ═══════════════════════════════════════════════════════════
# 7. Price API
# ═══════════════════════════════════════════════════════════
COINGECKO_API_KEY=

# ═══════════════════════════════════════════════════════════
# 8. Build-time Secrets (REQUIRED for release builds)
# ═══════════════════════════════════════════════════════════
# Generate with: openssl rand -hex 32
CLIENT_HMAC_SECRET=
# Generate with: scripts/extract_tls_pins.sh
TLS_PIN_SHA256=
